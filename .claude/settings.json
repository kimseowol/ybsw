{
  "permissions": {
    "deny": [
      "Edit(docs/design/**)",
      "Write(docs/design/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"${CLAUDE_PROJECT_DIR}/scripts/setup.ps1\" -Quiet",
            "statusMessage": "개발 환경 셋업 확인 (멱등)",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "pwsh -NoProfile -File \"${CLAUDE_PROJECT_DIR}/scripts/hooks/precommit-context.ps1\"",
            "statusMessage": "PRD 자가 점검 컨텍스트 수집",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
