{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/scripts/hooks/run-codex-hook.ps1\" setup",
            "commandWindows": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) 'scripts/hooks/run-codex-hook.ps1') setup\"",
            "statusMessage": "개발 환경 셋업 확인 (멱등)",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/scripts/hooks/run-codex-hook.ps1\" precommit-context",
            "commandWindows": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) 'scripts/hooks/run-codex-hook.ps1') precommit-context\"",
            "statusMessage": "PRD 자가 점검 컨텍스트 수집",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/scripts/hooks/run-codex-hook.ps1\" deny-design-edit",
            "commandWindows": "pwsh -NoProfile -Command \"& (Join-Path (git rev-parse --show-toplevel) 'scripts/hooks/run-codex-hook.ps1') deny-design-edit\"",
            "statusMessage": "docs/design 보호 확인",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
